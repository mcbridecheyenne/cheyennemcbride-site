<%- include('partials/header') %>

  <!-- Hero Banner -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="hero-title">Cheyenne McBride</h1>
      <p class="hero-tagline">Archer · Outdoorsman · Texas</p>
    </div>
  </section>

  <!-- About -->
  <section class="section" id="about">
    <div class="container">
      <h2 class="section-title">About</h2>
      <div class="about-content">
        <p>Welcome. I'm Cheyenne — an archer and outdoorsman based in Texas. This is my corner of the internet where I share what I'm working on and what I care about.</p>
      </div>
    </div>
  </section>

  <!-- Interests -->
  <section class="section section-alt" id="interests">
    <div class="container">
      <h2 class="section-title">Interests</h2>
      <div class="card-grid">
        <div class="card">
          <div class="card-icon">🏹</div>
          <h3 class="card-title">Archery</h3>
          <p class="card-text">Traditional and compound bow shooting. Always chasing tighter groupings.</p>
        </div>
        <div class="card">
          <div class="card-icon">🌲</div>
          <h3 class="card-title">Outdoors</h3>
          <p class="card-text">Hunting, hiking, and spending time in the Texas backcountry.</p>
        </div>
        <div class="card">
          <div class="card-icon">⚙️</div>
          <h3 class="card-title">Projects</h3>
          <p class="card-text">Building things — digital and physical. Always tinkering.</p>
        </div>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
