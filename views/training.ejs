    { cat: 'Shooting', text: 'Volume session — 180-300 arrows, mix distances' },
    { cat: 'Drill', text: 'Field Simulation — mix distances 10ft-55yd in one session' },
    { cat: 'Drill', text: 'Crawl Charting — verify and adjust your crawl marks <a href="https://www.youtube.com/watch?v=tHvS6ZdHBrM" target="_blank" class="t-inline-link">▶ Video</a>' },
    { cat: 'Logging', text: 'Log session: total arrows, fatigue notes, form breakdown point' }
  ]},
  6: { type: 'shoot', label: 'Long Session', emoji: '🏹', tasks: [
    { cat: 'Warm-up', text: '10-15 min warm-up (march in place, arm circles)' },
    { cat: 'Shooting', text: 'Blank Bale warm-up — 20 arrows for form <a href="https://www.youtube.com/playlist?list=PLxJp-Eauwqq3mSEG6SMZ_r0v5RDjfr4tJ" target="_blank" class="t-inline-link">▶ Video</a>' },
    { cat: 'Shooting', text: 'Long session — 200-350 arrows, all distances' },
    { cat: 'Drill', text: '20yd Indoor Scoring — 5-arrow ends, track scores' },
    { cat: 'Drill', text: 'Progressive Distance Walk — full range 10ft to 55yd <a href="https://www.youtube.com/watch?v=kE3oEmD31WY" target="_blank" class="t-inline-link">▶ Video</a>' },
    { cat: 'Drill', text: 'Field Simulation — random distances, competition mindset' },
    { cat: 'Logging', text: 'Log session: total arrows, best scores, weekly reflections' }
  ]}
};

// ─── State ───
let checksCache = {};
let weekOffset = 0;

// ─── Date Helpers ───
function formatDate(d) { return d.toISOString().split('T')[0]; }
function friendlyDate(d) { return d.toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' }); }
function isToday(d) { return d.toDateString() === new Date().toDateString(); }
function getDayTasks(d) { return SCHEDULE[d.getDay()]; }

// ─── API ───
async function loadChecks(dateStr) {
  if (checksCache[dateStr] !== undefined) return checksCache[dateStr];
  try {
    const r = await fetch('/api/training/checks?date=' + dateStr);
    const data = await r.json();
    checksCache[dateStr] = data.checks || {};
    return checksCache[dateStr];
  } catch (e) {
    console.error('Failed to load checks:', e);
    return {};
  }
}

async function loadChecksRange(startStr, endStr) {
  try {
    const r = await fetch('/api/training/checks/range?start=' + startStr + '&end=' + endStr);
    const data = await r.json();
    if (data.days) {
      Object.keys(data.days).forEach(d => { checksCache[d] = data.days[d]; });
    }
    return data.days || {};
  } catch (e) {
    console.error('Failed to load range:', e);
    return {};
  }
}

async function saveCheck(dateStr, taskIndex, checked) {
  if (!checksCache[dateStr]) checksCache[dateStr] = {};
  checksCache[dateStr][taskIndex] = checked;
  try {
    await fetch('/api/training/check', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ date: dateStr, taskIndex, checked })
    });
  } catch (e) {
    console.error('Failed to save check:', e);
  }
}

// ─── Session Cache ───
let sessionCache = {};

async function loadSession(dateStr) {
  if (sessionCache[dateStr] !== undefined) return sessionCache[dateStr];
  try {
    const r = await fetch('/api/training/session?date=' + dateStr);
    const data = await r.json();
    sessionCache[dateStr] = data;
    return data;
  } catch (e) {
    console.error('Failed to load session:', e);
    return { arrow_count: 0, notes: '', finished: false };
  }
}

async function loadSessionsRange(startStr, endStr) {
  try {
    const r = await fetch('/api/training/sessions/range?start=' + startStr + '&end=' + endStr);
    const data = await r.json();
    if (data.sessions) {
      Object.keys(data.sessions).forEach(d => { sessionCache[d] = data.sessions[d]; });
    }
    return data.sessions || {};
  } catch (e) { return {}; }
}

// ─── Tabs ───
function switchTab(name) {
  document.querySelectorAll('.training-tab').forEach(t => t.classList.toggle('active', t.dataset.tab === name));
  ['today', 'week', 'stats', 'plan'].forEach(id => {
    document.getElementById('tab-' + id).style.display = id === name ? 'block' : 'none';
  });
  if (name === 'today') renderToday();
  if (name === 'week') renderWeek();
  if (name === 'stats') renderStats();
}

// ─── Render Today ───
async function renderToday() {
  const now = new Date();
  const dateStr = formatDate(now);
  const dayInfo = getDayTasks(now);
  const checks = await loadChecks(dateStr);
  const session = await loadSession(dateStr);
  const isShootDay = dayInfo.type === 'shoot';

  const completed = dayInfo.tasks.filter((_, i) => checks[i]).length;
  const total = dayInfo.tasks.length;
  const pct = total ? Math.round((completed / total) * 100) : 0;
  const color = pct === 100 ? 'var(--color-success)' : 'var(--color-accent)';

  let html = `
    <div style="margin-bottom: 20px;">
      <h2 style="font-size: 1.3rem; margin-bottom: 4px;">${friendlyDate(now)}</h2>
      <div style="display: flex; align-items: center; gap: 12px; margin-top: 8px;">
        <span style="color: var(--color-text-muted); font-size: 0.85rem;">${dayInfo.emoji} ${dayInfo.label}</span>
        <span style="color: ${color}; font-weight: 600; font-size: 0.85rem;">${pct}% complete</span>
      </div>
      <div class="t-full-progress">
        <div class="t-full-progress-fill" style="width: ${pct}%; background: ${color};"></div>
      </div>
    </div>
  `;

  // Arrow counter (only on shooting days)
  if (isShootDay) {
    const arrows = session.arrow_count || 0;
    const finished = session.finished || false;
    // Get suggested range from schedule
    const ranges = { 1: [150, 250], 3: [120, 200], 5: [180, 300], 6: [200, 350] };
    const range = ranges[now.getDay()] || [150, 300];
    const arrowPct = Math.min(100, Math.round((arrows / range[1]) * 100));

    if (finished) {
      html += `
        <div class="arrow-counter">
          <div class="arrow-counter-title">🏹 Arrow Counter</div>
          <div class="arrow-finished">
            ✅ Session complete — <strong>${arrows} arrows</strong> logged today
          </div>
          <div style="margin-top: 12px; display: flex; gap: 8px;">
            <button class="arrow-btn" onclick="reopenSession('${dateStr}')">🔓 Reopen Session</button>
          </div>
        </div>
      `;
    } else {
      html += `
        <div class="arrow-counter">
          <div class="arrow-counter-title">🏹 Arrow Counter</div>
          <div class="arrow-counter-row">
            <div>
              <div class="arrow-count-display" id="arrowDisplay">${arrows}</div>
              <div style="font-size: 0.75rem; color: var(--color-text-muted); text-align: center;">arrows shot</div>
            </div>
            <div style="flex: 1;">
              <div style="font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 6px;">Quick add per end:</div>
              <div class="arrow-quick-add">
                <button class="arrow-btn" onclick="addArrows('${dateStr}', 3)">+3</button>
                <button class="arrow-btn" onclick="addArrows('${dateStr}', 5)">+5</button>
                <button class="arrow-btn" onclick="addArrows('${dateStr}', 6)">+6</button>
                <button class="arrow-btn" onclick="addArrows('${dateStr}', 10)">+10</button>
                <input type="number" class="arrow-custom-input" id="customArrowInput" placeholder="#" min="1" max="100">
                <button class="arrow-btn primary" onclick="addCustomArrows('${dateStr}')">Add</button>
              </div>
              <div style="margin-top: 10px; display: flex; align-items: center; gap: 8px;">
                <div class="t-progress-bar" style="flex: 1; height: 6px;">
                  <div class="t-progress-fill ${arrowPct >= 100 ? 'complete' : ''}" style="width: ${arrowPct}%"></div>
                </div>
                <span style="font-size: 0.75rem; color: var(--color-text-muted);">${arrows}/${range[0]}-${range[1]} target</span>
              </div>
              <div style="margin-top: 10px; display: flex; gap: 8px; flex-wrap: wrap;">
                <button class="arrow-btn" onclick="subtractArrows('${dateStr}', 1)">− 1</button>
                <button class="arrow-btn danger" onclick="resetArrows('${dateStr}')">Reset</button>
                ${arrows >= range[0] ? `<button class="arrow-btn finish" onclick="finishSession('${dateStr}')">\u2705 Finish Session</button>` : ''}
              </div>
            </div>
          </div>
        </div>
      `;
    }
  }

  html += `
    <div class="t-day open t-today">
      <div class="t-day-body" style="display: block; padding-top: 16px;">
        <ul class="t-checklist">
  `;

  dayInfo.tasks.forEach((task, i) => {
    const checked = !!checks[i];
    html += `
      <li>
        <input type="checkbox" ${checked ? 'checked' : ''} onchange="toggleCheck('${dateStr}', ${i}, this.checked, 'today')">
        <div class="t-item-text ${checked ? 'done' : ''}">
          <span class="t-item-cat">${task.cat}</span>
          ${task.text}
        </div>
      </li>
    `;
  });

  html += '</ul></div></div>';
  document.getElementById('tab-today').innerHTML = html;
}

// ─── Arrow Actions ───
async function addArrows(dateStr, count) {
  const session = await loadSession(dateStr);
  const newCount = (session.arrow_count || 0) + count;
  sessionCache[dateStr] = { ...session, arrow_count: newCount };
  await fetch('/api/training/session/arrows', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ date: dateStr, arrow_count: newCount })
  });
  renderToday();
}

function addCustomArrows(dateStr) {
  const input = document.getElementById('customArrowInput');
  const val = parseInt(input.value);
  if (val > 0) {
    addArrows(dateStr, val);
    input.value = '';
  }
}

async function subtractArrows(dateStr, count) {
  const session = await loadSession(dateStr);
  const newCount = Math.max(0, (session.arrow_count || 0) - count);
  sessionCache[dateStr] = { ...session, arrow_count: newCount };
  await fetch('/api/training/session/arrows', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ date: dateStr, arrow_count: newCount })
  });
  renderToday();
}

async function resetArrows(dateStr) {
  if (!confirm('Reset arrow count to 0?')) return;
  sessionCache[dateStr] = { arrow_count: 0, notes: '', finished: false };
  await fetch('/api/training/session/arrows', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ date: dateStr, arrow_count: 0 })
  });
  renderToday();
}

async function finishSession(dateStr) {
  sessionCache[dateStr] = { ...sessionCache[dateStr], finished: true };
  await fetch('/api/training/session/finish', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ date: dateStr })
  });
  renderToday();
}

async function reopenSession(dateStr) {
  sessionCache[dateStr] = { ...sessionCache[dateStr], finished: false };
  await fetch('/api/training/session/reopen', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ date: dateStr })
  });
  renderToday();
}

// ─── Render Week ───
async function renderWeek() {
  const now = new Date();
  const startOfWeek = new Date(now);
  startOfWeek.setDate(now.getDate() - now.getDay() + (weekOffset * 7));

  const days = [];
  for (let i = 0; i < 7; i++) {
    const d = new Date(startOfWeek);
    d.setDate(startOfWeek.getDate() + i);
    days.push(d);
  }

  const startStr = formatDate(days[0]);
  const endStr = formatDate(days[6]);
  await loadChecksRange(startStr, endStr);
  await loadSessionsRange(startStr, endStr);

  const weekStartLabel = days[0].toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  const weekEndLabel = days[6].toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

  let html = `
    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 20px;">
      <button class="t-nav-btn" onclick="changeWeek(-1)">←</button>
      <span style="font-size: 0.95rem; font-weight: 600;">${weekStartLabel} — ${weekEndLabel}</span>
      <button class="t-nav-btn" onclick="changeWeek(1)">→</button>
    </div>
  `;

  const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

  for (const d of days) {
    const dateStr = formatDate(d);
    const dayInfo = getDayTasks(d);
    const checks = checksCache[dateStr] || {};
    const completed = dayInfo.tasks.filter((_, i) => checks[i]).length;
    const total = dayInfo.tasks.length;
    const pct = total ? Math.round((completed / total) * 100) : 0;
    const today = isToday(d);
    const sess = sessionCache[dateStr] || {};
    const dayArrows = sess.arrow_count || 0;
    const dayFinished = sess.finished || false;

    html += `
      <div class="t-day ${today ? 't-today' : ''}" id="day-${dateStr}">
        <div class="t-day-head" onclick="toggleDayCard('${dateStr}')">
          <div class="t-day-name">
            ${dayNames[d.getDay()]} ${d.getDate()} ${dayInfo.emoji}
            ${today ? '<span class="t-badge">TODAY</span>' : ''}
            <span class="t-type-badge">${dayInfo.label}</span>
            ${dayInfo.type === 'shoot' && dayArrows > 0 ? `<span class="t-type-badge" style="background: var(--color-accent-light); color: var(--color-accent-hover);">${dayArrows} arrows${dayFinished ? ' ✅' : ''}</span>` : ''}
          </div>
          <div class="t-day-progress">
            <span class="pct ${pct === 100 ? 'complete' : ''}">${pct}%</span>
            <div class="t-progress-bar">
              <div class="t-progress-fill ${pct === 100 ? 'complete' : ''}" style="width: ${pct}%"></div>
            </div>
            <span>${completed}/${total}</span>
          </div>
        </div>
        <div class="t-day-body">
          <ul class="t-checklist">
    `;

    dayInfo.tasks.forEach((task, i) => {
      const checked = !!checks[i];
      html += `
        <li>
          <input type="checkbox" ${checked ? 'checked' : ''} onchange="toggleCheck('${dateStr}', ${i}, this.checked, 'week')">
          <div class="t-item-text ${checked ? 'done' : ''}">
            <span class="t-item-cat">${task.cat}</span>
            ${task.text}
          </div>
        </li>
      `;
    });

    html += '</ul></div></div>';
  }

  document.getElementById('tab-week').innerHTML = html;
}

function toggleDayCard(dateStr) {
  document.getElementById('day-' + dateStr).classList.toggle('open');
}

function changeWeek(dir) {
  weekOffset += dir;
  renderWeek();
}

async function toggleCheck(dateStr, taskIndex, checked, from) {
  await saveCheck(dateStr, taskIndex, checked);
  if (from === 'today') renderToday();
  if (from === 'week') renderWeek();
}

// ─── Render Stats ───
async function renderStats() {
  const now = new Date();
  const d28ago = new Date(now);
  d28ago.setDate(now.getDate() - 27);
  await loadChecksRange(formatDate(d28ago), formatDate(now));
  await loadSessionsRange(formatDate(d28ago), formatDate(now));

  // Also fetch arrow stats from the API
  let arrowStats = { all_time: { total: 0, sessions: 0 }, last_28: { total: 0, sessions: 0, avg: 0 }, this_week: { total: 0, sessions: 0 }, best_session: { arrows: 0, date: null } };
  try {
    const r = await fetch('/api/training/arrow-stats');
    arrowStats = await r.json();
  } catch (e) {}

  let totalTasks = 0, completedTasks = 0, daysTracked = 0, perfectDays = 0;
  let currentStreak = 0, streakBroken = false;
  const last14 = [];

  for (let i = 27; i >= 0; i--) {
    const d = new Date(now);
    d.setDate(now.getDate() - i);
    const dateStr = formatDate(d);
    const dayInfo = getDayTasks(d);
    const checks = checksCache[dateStr] || {};
    const total = dayInfo.tasks.length;
    const completed = dayInfo.tasks.filter((_, idx) => checks[idx]).length;
    const hasData = Object.keys(checks).length > 0;

    totalTasks += total;
    completedTasks += completed;
    if (hasData) daysTracked++;
    if (completed === total && hasData) perfectDays++;

    if (i < 14) {
      last14.push({ date: d, completed, total, pct: total ? Math.round((completed / total) * 100) : 0 });
    }

    if (i <= 13 && !streakBroken) {
      if (hasData && completed === total) currentStreak++;
      else if (hasData) streakBroken = true;
    }
  }

  const overallPct = totalTasks ? Math.round((completedTasks / totalTasks) * 100) : 0;

  // Today
  const todayStr = formatDate(now);
  const todayInfo = getDayTasks(now);
  const todayChecks = checksCache[todayStr] || {};
  const todayCompleted = todayInfo.tasks.filter((_, i) => todayChecks[i]).length;
  const todayTotal = todayInfo.tasks.length;
  const todayPct = todayTotal ? Math.round((todayCompleted / todayTotal) * 100) : 0;

  // This week
  const startOfWeek = new Date(now);
  startOfWeek.setDate(now.getDate() - now.getDay());
  let weekTasks = 0, weekCompleted = 0;
  for (let i = 0; i < 7; i++) {
    const d = new Date(startOfWeek);
    d.setDate(startOfWeek.getDate() + i);
    const dayInfo = getDayTasks(d);
    const checks = checksCache[formatDate(d)] || {};
    weekTasks += dayInfo.tasks.length;
    weekCompleted += dayInfo.tasks.filter((_, idx) => checks[idx]).length;
  }
  const weekPct = weekTasks ? Math.round((weekCompleted / weekTasks) * 100) : 0;

  const colorClass = (pct) => pct >= 80 ? 't-green' : pct >= 50 ? 't-accent' : 't-red';

  let html = `
    <div class="t-stats-grid">
      <div class="t-stat">
        <div class="t-stat-label">Today</div>
        <div class="t-stat-value ${colorClass(todayPct)}">${todayPct}%</div>
        <div class="t-stat-sub">${todayCompleted}/${todayTotal} tasks</div>
      </div>
      <div class="t-stat">
        <div class="t-stat-label">This Week</div>
        <div class="t-stat-value ${colorClass(weekPct)}">${weekPct}%</div>
        <div class="t-stat-sub">${weekCompleted}/${weekTasks} tasks</div>
      </div>
      <div class="t-stat">
        <div class="t-stat-label">28-Day Average</div>
        <div class="t-stat-value ${colorClass(overallPct)}">${overallPct}%</div>
        <div class="t-stat-sub">${completedTasks}/${totalTasks} tasks</div>
      </div>
      <div class="t-stat">
        <div class="t-stat-label">Perfect Days (28d)</div>
        <div class="t-stat-value t-accent">${perfectDays}</div>
        <div class="t-stat-sub">100% completion days</div>
      </div>
    </div>

    <div class="t-stats-grid" style="margin-bottom: 24px;">
      <div class="t-stat">
        <div class="t-stat-label">🔥 Current Streak</div>
        <div class="t-stat-value t-green">${currentStreak}</div>
        <div class="t-stat-sub">perfect days in a row</div>
      </div>
      <div class="t-stat">
        <div class="t-stat-label">Days Tracked (28d)</div>
        <div class="t-stat-value t-accent">${daysTracked}</div>
        <div class="t-stat-sub">out of 28 days</div>
      </div>
    </div>

    <div class="t-card">
      <h3 class="t-card-title">📊 Last 14 Days</h3>
      <div class="t-bar-chart">
  `;

  const dayLabels = ['S','M','T','W','T','F','S'];
  last14.forEach(day => {
    const h = day.pct > 0 ? Math.max(day.pct, 5) : 0;
    html += `
      <div class="t-bar-col">
        <div class="t-bar ${h === 0 ? 'empty' : ''}" style="height: ${h}%; ${day.pct === 100 ? 'background: var(--color-success);' : ''}" title="${day.date.toLocaleDateString()}: ${day.pct}%"></div>
        <div class="t-bar-label">${dayLabels[day.date.getDay()]}</div>
      </div>
    `;
  });

  html += `
      </div>
    </div>

    <div class="t-card" style="margin-top: 16px;">
      <h3 class="t-card-title">🏹 Arrow Stats</h3>
      <div class="t-stats-grid" style="margin-top: 12px;">
        <div class="t-stat">
          <div class="t-stat-label">This Week</div>
          <div class="t-stat-value t-accent">${arrowStats.this_week.total}</div>
          <div class="t-stat-sub">${arrowStats.this_week.sessions} session${arrowStats.this_week.sessions !== 1 ? 's' : ''}</div>
        </div>
        <div class="t-stat">
          <div class="t-stat-label">Last 28 Days</div>
          <div class="t-stat-value t-accent">${arrowStats.last_28.total}</div>
          <div class="t-stat-sub">ø ${arrowStats.last_28.avg} per session</div>
        </div>
        <div class="t-stat">
          <div class="t-stat-label">All Time</div>
          <div class="t-stat-value t-green">${arrowStats.all_time.total}</div>
          <div class="t-stat-sub">${arrowStats.all_time.sessions} session${arrowStats.all_time.sessions !== 1 ? 's' : ''} logged</div>
        </div>
        <div class="t-stat">
          <div class="t-stat-label">Best Session</div>
          <div class="t-stat-value t-accent">${arrowStats.best_session.arrows}</div>
          <div class="t-stat-sub">${arrowStats.best_session.date || '—'}</div>
        </div>
      </div>
    </div>

    <div class="t-card" style="margin-top: 16px;">
      <h3 class="t-card-title">💡 Tips</h3>
      <ul class="t-list">
        <li>Complete all tasks for a day to earn a 🔥 streak day</li>
        <li>Check off tasks as you go — saves automatically to your account</li>
        <li>Aim for 80%+ weekly to stay on track</li>
        <li>Rest days count too — recovery is part of training!</li>
      </ul>
    </div>
  `;

  document.getElementById('tab-stats').innerHTML = html;
}

// ─── Nav Button Style (injected) ───
const style = document.createElement('style');
style.textContent = `
  .t-nav-btn {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition);
  }
  .t-nav-btn:hover { border-color: var(--color-accent); }
`;
document.head.appendChild(style);

// ─── Init ───
renderToday();
</script>

<%- include('partials/footer') %>
